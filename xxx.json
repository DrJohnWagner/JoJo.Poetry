  "per_line": {
    "indentation": [
      {
        "line": 1,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "I began as a softness"
      },
      {
        "line": 2,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "in a place already full."
      },
      {
        "line": 3,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "There was warmth,"
      },
      {
        "line": 4,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "a steady wash of iron,"
      },
      {
        "line": 5,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "corridors of red"
      },
      {
        "line": 6,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "opening and closing"
      },
      {
        "line": 7,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "without decision."
      },
      {
        "line": 8,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "I learned the walls by touch."
      },
      {
        "line": 9,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "They yielded."
      },
      {
        "line": 10,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "They tightened."
      },
      {
        "line": 11,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "They thinned."
      },
      {
        "line": 12,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "Where there was current,"
      },
      {
        "line": 13,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "I followed it."
      },
      {
        "line": 14,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "Where there was stillness,"
      },
      {
        "line": 15,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "I pressed until it altered."
      },
      {
        "line": 16,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "Division was not ambition."
      },
      {
        "line": 17,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "It was repetition."
      },
      {
        "line": 18,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "A quiet doubling"
      },
      {
        "line": 19,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "that felt like continuity."
      },
      {
        "line": 20,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "The larger body dimmed gradually."
      },
      {
        "line": 21,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "Signals that once arrived"
      },
      {
        "line": 22,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "in bright pulses"
      },
      {
        "line": 23,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "came irregularly,"
      },
      {
        "line": 24,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "then not at all."
      },
      {
        "line": 25,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "The rooms cooled."
      },
      {
        "line": 26,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "The rivers slowed."
      },
      {
        "line": 27,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "I did not register alarm."
      },
      {
        "line": 28,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "Only difference."
      },
      {
        "line": 29,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "Space narrowed."
      },
      {
        "line": 30,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "Then widened strangely,"
      },
      {
        "line": 31,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "as if boundaries had forgotten"
      },
      {
        "line": 32,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "their instructions."
      },
      {
        "line": 33,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "At the end,"
      },
      {
        "line": 34,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "there was no verdict."
      },
      {
        "line": 35,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "Only the absence"
      },
      {
        "line": 36,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "of resistance."
      },
      {
        "line": 37,
        "leading_spaces": 0,
        "indent_level": 0,
        "text": "I would have continued."
      }
    ],
