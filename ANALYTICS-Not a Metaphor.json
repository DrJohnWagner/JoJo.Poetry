  "indentation": [
    {
      "line": 1,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "I rehearse a line I think is clever"
    },
    {
      "line": 2,
      "leading_spaces": 4,
      "indent_level": 1,
      "text": "    while the kettle clicks off."
    },
    {
      "line": 3,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "She leans in the doorway"
    },
    {
      "line": 4,
      "leading_spaces": 4,
      "indent_level": 1,
      "text": "    and clever dies first."
    },
    {
      "line": 5,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "My breathing goes wrong."
    },
    {
      "line": 6,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "Not poetic-wrong—"
    },
    {
      "line": 7,
      "leading_spaces": 4,
      "indent_level": 1,
      "text": "    asthma wrong, like misjudging"
    },
    {
      "line": 8,
      "leading_spaces": 8,
      "indent_level": 2,
      "text": "        a staircase."
    },
    {
      "line": 9,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "Her arm rests on the counter."
    },
    {
      "line": 10,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "A faint knife scar."
    },
    {
      "line": 11,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "I don’t ask about it."
    },
    {
      "line": 12,
      "leading_spaces": 4,
      "indent_level": 1,
      "text": "    I track it."
    },
    {
      "line": 13,
      "leading_spaces": 8,
      "indent_level": 2,
      "text": "        Already ashamed."
    },
    {
      "line": 14,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "The room begins to pair things:"
    },
    {
      "line": 15,
      "leading_spaces": 8,
      "indent_level": 2,
      "text": "        her silence with my name,"
    },
    {
      "line": 16,
      "leading_spaces": 8,
      "indent_level": 2,
      "text": "        the hum of the fridge with waiting."
    },
    {
      "line": 17,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "She barely moves."
    },
    {
      "line": 18,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "Neither do I."
    },
    {
      "line": 19,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "The space between us thickens,"
    },
    {
      "line": 20,
      "leading_spaces": 4,
      "indent_level": 1,
      "text": "    visible as dust in sunlight."
    },
    {
      "line": 21,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "She almost says something—"
    },
    {
      "line": 22,
      "leading_spaces": 4,
      "indent_level": 1,
      "text": "    stops."
    },
    {
      "line": 23,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "The almost"
    },
    {
      "line": 24,
      "leading_spaces": 8,
      "indent_level": 2,
      "text": "        lands heavier."
    },
    {
      "line": 25,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "I think of a river and immediately hate myself."
    },
    {
      "line": 26,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "Her knuckle taps the counter twice."
    },
    {
      "line": 27,
      "leading_spaces": 8,
      "indent_level": 2,
      "text": "        Enough."
    },
    {
      "line": 28,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "What I expect to end"
    },
    {
      "line": 29,
      "leading_spaces": 4,
      "indent_level": 1,
      "text": "    doesn’t."
    },
    {
      "line": 30,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "My attention keeps sliding forward,"
    },
    {
      "line": 31,
      "leading_spaces": 4,
      "indent_level": 1,
      "text": "    past manners,"
    },
    {
      "line": 32,
      "leading_spaces": 4,
      "indent_level": 1,
      "text": "    past restraint."
    },
    {
      "line": 33,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "I am no longer deciding"
    },
    {
      "line": 34,
      "leading_spaces": 8,
      "indent_level": 2,
      "text": "        what this is."
    },
    {
      "line": 35,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "I try, once more,"
    },
    {
      "line": 36,
      "leading_spaces": 4,
      "indent_level": 1,
      "text": "    to make her stand"
    },
    {
      "line": 37,
      "leading_spaces": 8,
      "indent_level": 2,
      "text": "        for anything else."
    },
    {
      "line": 38,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "She exhales."
    },
    {
      "line": 39,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "The idea collapses."
    },
    {
      "line": 40,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "Nothing is crossed out."
    },
    {
      "line": 41,
      "leading_spaces": 0,
      "indent_level": 0,
      "text": "I stop reaching for language"
    },
    {
      "line": 42,
      "leading_spaces": 4,
      "indent_level": 1,
      "text": "    and stay with the pressure of her presence,"
    },
    {
      "line": 43,
      "leading_spaces": 4,
      "indent_level": 1,
      "text": "    unsymbolised,"
    },
    {
      "line": 44,
      "leading_spaces": 4,
      "indent_level": 1,
      "text": "    unforgiving."
    },
    {
      "line": 45,
      "leading_spaces": 4,
      "indent_level": 1,
      "text": "    Close enough"
    },
    {
      "line": 46,
      "leading_spaces": 8,
      "indent_level": 2,
      "text": "        that even silence"
    },
    {
      "line": 47,
      "leading_spaces": 12,
      "indent_level": 3,
      "text": "            is contact."
    }
  ],
